# Low stock rules
LOW_STOCK_THRESHOLD=10
LOW_STOCK_COOLDOWN_HOURS=24

# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio sender numbers
TWILIO_SMS_FROM=+1xxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Receiver numbers (pre-filled)
LOW_STOCK_SMS_TO=+917666150423
LOW_STOCK_WHATSAPP_TO=whatsapp:+917666150423

# Optional Telegram channel (easy + free)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional email channel
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@example.com
SMTP_PASSWORD=your_email_app_password
SMTP_USE_TLS=true
LOW_STOCK_EMAIL_TO=youremail@example.com
LOW_STOCK_EMAIL_FROM=youremail@example.com
